{
  "name": "hoopit-skills",
  "owner": {
    "name": "Hoopit",
    "email": "lars-kristian@hoopit.io"
  },
  "metadata": {
    "description": "Hoopit agent skills, distributed as Claude Code plugins."
  },
  "plugins": [
    {
      "name": "hoopit-onboarding",
      "source": "./plugins/onboarding",
      "description": "Take a fresh machine to a working hoopit/api or hoopit/flutter-app checkout, plus the supporting CLIs."
    },
    {
      "name": "hoopit-dev",
      "source": "./plugins/dev",
      "description": "Day-to-day dev workflows and CLIs: Jira/Sentry issues, PR review, Atlassian, CircleCI."
    },
    {
      "name": "hoopit-misc",
      "source": "./plugins/misc",
      "description": "Odds and ends: status line."
    },
    {
      "name": "hoopit-product",
      "source": "./plugins/product",
      "description": "Product work: stress-test plans and ideas against the domain model, sharpen terminology, and produce a PRD."
    },
    {
      "name": "hoopit-matt-picks",
      "source": {
        "source": "github",
        "repo": "mattpocock/skills"
      },
      "strict": true,
      "description": "Curated picks from mattpocock/skills, tracking upstream.",
      "skills": [
        "./skills/engineering/ask-matt",
        "./skills/engineering/codebase-design",
        "./skills/engineering/diagnosing-bugs",
        "./skills/engineering/domain-modeling",
        "./skills/engineering/grill-with-docs",
        "./skills/engineering/implement",
        "./skills/engineering/improve-codebase-architecture",
        "./skills/engineering/prototype",
        "./skills/engineering/resolving-merge-conflicts",
        "./skills/engineering/setup-matt-pocock-skills",
        "./skills/engineering/tdd",
        "./skills/engineering/to-issues",
        "./skills/engineering/to-prd",
        "./skills/engineering/triage",
        "./skills/in-progress/decision-mapping",
        "./skills/in-progress/loop-me",
        "./skills/in-progress/review",
        "./skills/productivity/handoff",
        "./skills/productivity/teach",
        "./skills/productivity/writing-great-skills"
      ]
    }
  ]
}
