{
  "name": "hoopit-skills",
  "metadata": {
    "description": "Hoopit agent skills, grouped for the `skills` CLI."
  },
  "plugins": [
    {
      "name": "hoopit-onboarding",
      "skills": [
        "./skills/api-onboarding",
        "./skills/flutter-onboarding",
        "./skills/install-sentry-cli",
        "./skills/install-coderabbit-cli"
      ]
    },
    {
      "name": "hoopit-workflows",
      "skills": [
        "./skills/handle-jira-issue",
        "./skills/fix-sentry-issue",
        "./skills/review-github-comments",
        "./skills/write-pull-request"
      ]
    },
    {
      "name": "hoopit-tools",
      "skills": [
        "./skills/atlassian-cli"
      ]
    },
    {
      "name": "hoopit-misc",
      "skills": [
        "./skills/setup-statusline",
        "./skills/grill-my-idea"
      ]
    }
  ]
}
